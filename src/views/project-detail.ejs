<%- include('partials/header') %>

<main class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/projects">Projects</a></li>
            <li class="breadcrumb-item active" aria-current="page"><%= project.project_name %></li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-lg border-0 overflow-hidden">
                <div class="bg-primary text-white p-5 text-center">
                    <h1 class="display-4 fw-bold mb-3"><%= project.project_name %></h1>
                    <div class="d-flex justify-content-center gap-4">
                        <span><i class="bi bi-geo-alt-fill me-2"></i><%= project.location %></span>
                        <span><i class="bi bi-calendar-event-fill me-2"></i><%= new Date(project.date).toLocaleDateString() %></span>
                    </div>
                </div>
                
                <div class="card-body p-5">
                    <div class="row">
                        <div class="col-md-8">
                            <h3 class="h4 fw-bold mb-4">Project Description</h3>
                            <p class="lead mb-5"><%= project.project_description %></p>
                            
                            <h3 class="h4 fw-bold mb-3">Categories</h3>
                            <div class="d-flex flex-wrap gap-2 mb-5">
                                <% if (categories && categories.length > 0) { %>
                                    <% categories.forEach(cat => { %>
                                        <a href="/categories/<%= cat.category_id %>" class="btn btn-outline-secondary rounded-pill px-4">
                                            <%= cat.category_name %>
                                        </a>
                                    <% }) %>
                                <% } else { %>
                                    <span class="text-muted">No categories assigned to this project.</span>
                                <% } %>
                            </div>
                        </div>
                        
                        <div class="col-md-4">
                            <div class="card bg-light border-0 p-4">
                                <h4 class="h5 fw-bold mb-3">Organization</h4>
                                <p class="mb-4">Hosted by <a href="/organizations/<%= project.organization_id %>" class="fw-bold"><%= project.organization_name %></a></p>
                                <a href="/signup" class="btn btn-primary w-100 rounded-pill py-2">Volunteer Now</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
