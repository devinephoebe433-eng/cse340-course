<%- include('partials/header') %>

<main class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/organizations">Organizations</a></li>
            <li class="breadcrumb-item active" aria-current="page"><%= organization.organization_name %></li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm border-0">
                <img src="/images/<%= organization.logo %>" class="card-img-top" alt="<%= organization.organization_name %> logo">
                <div class="card-body text-center">
                    <h2 class="h4 fw-bold mb-3"><%= organization.organization_name %></h2>
                    <p class="text-muted mb-4"><i class="bi bi-envelope-fill me-2"></i><%= organization.contact_email %></p>
                    <a href="mailto:<%= organization.contact_email %>" class="btn btn-primary w-100 rounded-pill">Contact Organization</a>
                </div>
            </div>
        </div>
        
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">
                    <h3 class="h5 fw-bold mb-3">About Us</h3>
                    <p class="lead"><%= organization.description %></p>
                </div>
            </div>

            <h3 class="h5 fw-bold mb-3">Projects by this Organization</h3>
            <div class="list-group shadow-sm">
                <% if (projects && projects.length > 0) { %>
                    <% projects.forEach(project => { %>
                        <a href="/projects/<%= project.project_id %>" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center p-3">
                            <div>
                                <h5 class="mb-1"><%= project.project_name %></h5>
                                <small class="text-muted"><i class="bi bi-geo-alt-fill me-1"></i><%= project.location %></small>
                            </div>
                            <span class="badge bg-primary rounded-pill"><%= new Date(project.date).toLocaleDateString() %></span>
                        </a>
                    <% }) %>
                <% } else { %>
                    <div class="list-group-item text-center py-4">
                        <p class="text-muted mb-0">No projects found for this organization.</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
