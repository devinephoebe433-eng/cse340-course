<%- include('partials/header') %>

<main class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/categories">Categories</a></li>
            <li class="breadcrumb-item active" aria-current="page"><%= category.category_name %></li>
        </ol>
    </nav>

    <div class="row mb-5">
        <div class="col-12 text-center">
            <h1 class="display-4 fw-bold">Projects in <%= category.category_name %></h1>
            <p class="lead text-muted">Explore all service projects tagged with this category.</p>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        <% if (projects && projects.length > 0) { %>
            <% projects.forEach(project => { %>
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 hover-shadow transition">
                        <div class="card-body">
                            <h5 class="card-title fw-bold text-primary mb-3"><%= project.project_name %></h5>
                            <p class="card-text text-muted mb-4"><%= project.project_description.substring(0, 100) %>...</p>
                            
                            <div class="mb-3">
                                <div class="d-flex align-items-center text-muted mb-2">
                                    <i class="bi bi-geo-alt-fill me-2 text-danger"></i>
                                    <span class="small"><%= project.location %></span>
                                </div>
                                <div class="d-flex align-items-center text-muted">
                                    <i class="bi bi-calendar-event-fill me-2 text-success"></i>
                                    <span class="small"><%= new Date(project.date).toLocaleDateString() %></span>
                                </div>
                            </div>
                            
                            <a href="/projects/<%= project.project_id %>" class="btn btn-outline-primary w-100 rounded-pill mt-auto">Learn More</a>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-12 text-center py-5">
                <p class="lead text-muted">No projects found for this category yet.</p>
                <a href="/projects" class="btn btn-primary rounded-pill px-4">Browse All Projects</a>
            </div>
        <% } %>
    </div>
</main>

<%- include('partials/footer') %>
