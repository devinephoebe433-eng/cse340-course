<%- include('partials/header') %>

<main class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 p-5">
                <div class="display-1 text-success mb-4">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
                <h1 class="display-4 fw-bold mb-3">Thank You, <%= name %>!</h1>
                <p class="lead text-muted mb-5">Your application to become a volunteer has been received. We'll be in touch with you shortly to discuss upcoming opportunities.</p>
                <div class="d-flex justify-content-center gap-3">
                    <a href="/projects" class="btn btn-primary rounded-pill px-4 py-2">Browse Projects</a>
                    <a href="/" class="btn btn-outline-secondary rounded-pill px-4 py-2">Return Home</a>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('partials/footer') %>
