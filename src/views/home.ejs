<%- include('partials/header') %>

<main>
    <!-- Hero Section -->
    <section class="bg-primary text-white py-5 mb-5">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <h1 class="display-3 fw-bold mb-4">Make a Difference Today</h1>
                    <p class="lead mb-5">Connect with local organizations and join meaningful service projects that impact your community.</p>
                    <div class="d-flex gap-3">
                        <a href="/projects" class="btn btn-light btn-lg rounded-pill px-4">Browse Projects</a>
                        <a href="/organizations" class="btn btn-outline-light btn-lg rounded-pill px-4">View Organizations</a>
                    </div>
                </div>
                <div class="col-lg-6 d-none d-lg-block">
                    <img src="/images/volunteers.jpg" alt="Volunteers working together" class="img-fluid rounded-3 shadow-lg">
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="container py-5">
        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="p-4 border rounded-3 h-100 hover-shadow transition">
                    <div class="display-4 text-primary mb-3"><i class="bi bi-people-fill"></i></div>
                    <h3 class="h4 fw-bold">Connect</h3>
                    <p class="text-muted">Join a community of like-minded individuals dedicated to service.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4 border rounded-3 h-100 hover-shadow transition">
                    <div class="display-4 text-primary mb-3"><i class="bi bi-trophy-fill"></i></div>
                    <h3 class="h4 fw-bold">Grow</h3>
                    <p class="text-muted">Develop new skills and gain valuable experience through hands-on work.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-4 border rounded-3 h-100 hover-shadow transition">
                    <div class="display-4 text-primary mb-3"><i class="bi bi-globe"></i></div>
                    <h3 class="h4 fw-bold">Impact</h3>
                    <p class="text-muted">Create lasting positive change in your local and global community.</p>
                </div>
            </div>
        </div>
    </section>
</main>

<%- include('partials/footer') %>
