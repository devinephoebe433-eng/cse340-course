<%- include('partials/header') %>

<link rel="stylesheet" href="/css/styles.css">

<main>

    <!-- Hero Section -->
    <section class="hero">

        <div class="hero-content">

            <h1><%= title %></h1>

            <p class="hero-text">
                Connecting passionate volunteers with meaningful opportunities
                that create positive change in our communities. Join organizations,
                discover inspiring projects, and make a lasting impact through
                service.
            </p>

            <div class="hero-buttons">

                <a href="/organizations" class="btn primary-btn">
                    Explore Organizations
                </a>

                <a href="/signup" class="btn secondary-btn">
                    Become a Volunteer
                </a>

            </div>

        </div>


        <div class="hero-image">

            <img
                src="/images/volunteers.jpg"
                alt="Volunteers working together">

        </div>

    </section>


    <!-- Mission Section -->
    <section class="mission">

        <h2>Making a Difference Together</h2>

        <p>
            We connect volunteers with organizations that need their time,
            skills, and passion. Every act of service helps build stronger,
            healthier, and more connected communities.
        </p>

    </section>


    <!-- Features Section -->
    <section class="features">

        <div class="feature-card">

            <div class="icon">🤝</div>

            <h3>Connect</h3>

            <p>
                Meet organizations that share your interests and values.
            </p>

        </div>


        <div class="feature-card">

            <div class="icon">🌍</div>

            <h3>Serve</h3>

            <p>
                Participate in meaningful projects that improve communities.
            </p>

        </div>


        <div class="feature-card">

            <div class="icon">⭐</div>

            <h3>Grow</h3>

            <p>
                Develop new skills, build friendships, and gain valuable
                volunteer experience.
            </p>

        </div>

    </section>


    <!-- Statistics Section -->
    <section class="mission">

        <h2>Our Impact</h2>

        <div class="features">

            <div class="feature-card">
                <h2>50+</h2>
                <p>Volunteer Organizations</p>
            </div>

            <div class="feature-card">
                <h2>150+</h2>
                <p>Community Projects</p>
            </div>

            <div class="feature-card">
                <h2>2,000+</h2>
                <p>Active Volunteers</p>
            </div>

        </div>

    </section>


    <!-- Call To Action -->
    <section class="cta">

        <h2>Ready to Make an Impact?</h2>

        <p>
            Become part of a growing community of volunteers making a
            difference every day. Find a project that inspires you and
            start serving today.
        </p>

        <a href="/organizations" class="btn primary-btn">
            Get Started Today
        </a>

    </section>

</main>

<%- include('partials/footer') %>