<%- include('partials/header') %>

<link rel="stylesheet" href="/css/styles.css">

<main>

    <!-- Projects Hero -->
    <section class="projects-hero">

        <h1><%= title %></h1>

        <p>
            Discover meaningful service projects where you can volunteer,
            develop new skills, and create a positive impact in your community.
        </p>

    </section>



    <!-- Projects Cards -->

    <section class="projects-grid">


        <div class="project-card">

            <div class="project-image">
                🌳
            </div>

            <div class="project-content">

                <h2>
                    Community Clean-Up Project
                </h2>

                <p class="project-category">
                    Environmental Service
                </p>

                <p>
                    Join volunteers working together to protect the environment,
                    clean public spaces, and promote sustainability.
                </p>


                <a href="/organizations" class="project-btn">
                    Join Project
                </a>

            </div>

        </div>



        <div class="project-card">

            <div class="project-image">
                📖
            </div>

            <div class="project-content">

                <h2>
                    Education Support Program
                </h2>

                <p class="project-category">
                    Educational Service
                </p>


                <p>
                    Help students succeed by providing mentorship,
                    tutoring, and learning support.
                </p>


                <a href="/organizations" class="project-btn">
                    Join Project
                </a>

            </div>

        </div>



        <div class="project-card">

            <div class="project-image">
                🏘️
            </div>


            <div class="project-content">

                <h2>
                    Community Development
                </h2>


                <p class="project-category">
                    Community Service
                </p>


                <p>
                    Participate in projects that improve neighborhoods
                    and strengthen communities.
                </p>


                <a href="/organizations" class="project-btn">
                    Join Project
                </a>


            </div>

        </div>



        <div class="project-card">

            <div class="project-image">
                🏥
            </div>


            <div class="project-content">

                <h2>
                    Health Awareness Campaign
                </h2>


                <p class="project-category">
                    Health & Wellness
                </p>


                <p>
                    Support programs that encourage healthy lifestyles
                    and improve community wellness.
                </p>


                <a href="/organizations" class="project-btn">
                    Join Project
                </a>


            </div>

        </div>


    </section>


</main>


<%- include('partials/footer') %>