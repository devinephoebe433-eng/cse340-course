<%- include('partials/header') %>

<link rel="stylesheet" href="/css/styles.css">

<main>

    <!-- Projects Hero -->
    <section class="projects-hero">

        <h1><%= title %></h1>

        <p>
            Discover meaningful service projects where you can volunteer,
            develop new skills, and create a positive impact in your community.
        </p>

    </section>



    <!-- Projects Cards -->

    <section class="projects-grid">

        <% if (projects && projects.length > 0) { %>
            <% projects.forEach(project => { %>
                <div class="project-card">

                    <div class="project-image">
                        🚀
                    </div>

                    <div class="project-content">

                        <h2>
                            <%= project.project_name %>
                        </h2>

                        <p class="project-org">
                            <strong>Organization:</strong> <%= project.organization_name %>
                        </p>

                        <p class="project-meta">
                            <strong>Location:</strong> <%= project.location %> | 
                            <strong>Date:</strong> <%= project.date ? new Date(project.date).toLocaleDateString() : 'TBD' %>
                        </p>

                        <p>
                            <%= project.project_description %>
                        </p>


                        <a href="/organizations" class="project-btn">
                            Join Project
                        </a>

                    </div>

                </div>
            <% }) %>
        <% } else { %>
            <p>No projects found.</p>
        <% } %>

    </section>


</main>


<%- include('partials/footer') %>
