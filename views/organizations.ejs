<%- include('partials/header') %>

<link rel="stylesheet" href="/css/styles.css">

<main class="organizations-page">

    <section class="hero">
        <h1><%= title %></h1>
        <p>
            Explore our partner organizations that inspire creativity,
            learning, and community engagement.
        </p>
    </section>

    <section class="organizations-grid">

        <% if (organizations && organizations.length > 0) { %>
            <% organizations.forEach(org => { %>
                <article class="org-card">
                    <img src="<%= org.logo || '/images/default-org.jpg' %>" alt="<%= org.organization_name %>">

                    <div class="org-content">
                        <h2><%= org.organization_name %></h2>

                        <p class="contact-email">
                            <strong>Contact:</strong> <%= org.contact_email %>
                        </p>

                        <p>
                            <%= org.description %>
                        </p>

                        <a href="#" class="btn">Learn More</a>
                    </div>
                </article>
            <% }) %>
        <% } else { %>
            <p>No organizations found.</p>
        <% } %>

    </section>

</main>

<%- include('partials/footer') %>
